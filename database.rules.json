{
  "rules": {
    "canvas": {
      "docs": {
        ".read": "auth != null",
        ".write": "auth != null"
      },
      "userinfo": {
        "$uid": {
          ".read": "auth != null && auth.uid == $uid",
          ".write": "auth != null && auth.uid == $uid"
        }
      }
    },
    "feedback": {
      ".read": "false",
      ".write": "auth != null"
    }
  }
}
